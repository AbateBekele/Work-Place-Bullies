<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Workplace Bullies — Abate Bekele Mergia</title>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,400;1,600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --forest:     #1a4a2e;
      --forest-dk:  #0f2e1b;
      --forest-lt:  #2d6b46;
      --gold:       #c9a84c;
      --gold-lt:    #e8d5a3;
      --gold-dk:    #8b6914;
      --cream:      #faf7f0;
      --paper:      #f4efe4;
      --ink:        #1a1a1a;
      --muted:      #5a6b5c;
      --white:      #ffffff;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--cream);
      color: var(--ink);
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ── GOLD ORNAMENT SVG ── */
    .ornament {
      display: block;
      margin: 0 auto;
      color: var(--gold);
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.9rem 3rem;
      background: rgba(15,46,27,0.97);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(201,168,76,0.3);
    }

    .nav-brand {
      font-family: 'Cinzel', serif;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      color: var(--gold);
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      gap: 2.2rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.65);
      text-decoration: none;
      transition: color 0.25s;
    }

    .nav-links a:hover { color: var(--gold); }

    .nav-cta {
      background: var(--gold) !important;
      color: var(--forest-dk) !important;
      padding: 0.4rem 1.1rem;
      border-radius: 2px;
      font-weight: 600 !important;
    }

    .nav-cta:hover { background: var(--gold-lt) !important; }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      background: linear-gradient(135deg, var(--forest-dk) 0%, var(--forest) 50%, var(--forest-lt) 100%);
      position: relative;
      display: flex;
      align-items: center;
      padding: 6rem 5% 5rem;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 80% at 10% 50%, rgba(201,168,76,0.08) 0%, transparent 60%),
        radial-gradient(ellipse 50% 60% at 90% 20%, rgba(201,168,76,0.06) 0%, transparent 50%);
      pointer-events: none;
    }

    /* floating leaf shapes */
    .hero-bg-leaf {
      position: absolute;
      opacity: 0.07;
      pointer-events: none;
    }

    .hero-bg-leaf.left {
      left: -80px; bottom: -60px;
      width: 500px; height: 500px;
      background: radial-gradient(ellipse at center, var(--gold) 0%, transparent 70%);
      border-radius: 50%;
    }

    .hero-bg-leaf.right {
      right: -100px; top: 10%;
      width: 400px; height: 600px;
      background: radial-gradient(ellipse at center, var(--gold) 0%, transparent 70%);
      border-radius: 50%;
    }

    .hero-inner {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
      position: relative;
      z-index: 2;
    }

    .hero-text { color: var(--white); }

    .hero-eyebrow {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.8rem;
    }

    .hero-eyebrow span {
      font-family: 'Cinzel', serif;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .hero-eyebrow::before,
    .hero-eyebrow::after {
      content: '';
      height: 1px;
      width: 40px;
      background: var(--gold);
      opacity: 0.6;
    }

    .hero-title {
      font-family: 'Cinzel', serif;
      font-size: clamp(2.5rem, 4.5vw, 4rem);
      font-weight: 900;
      line-height: 1.05;
      letter-spacing: 0.04em;
      margin-bottom: 0.2rem;
      color: var(--white);
      text-shadow: 0 2px 20px rgba(0,0,0,0.4);
    }

    .hero-title-gold {
      font-family: 'Cinzel', serif;
      font-size: clamp(3rem, 6vw, 5.5rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: 0.06em;
      background: linear-gradient(135deg, var(--gold-lt) 0%, var(--gold) 40%, var(--gold-dk) 70%, var(--gold) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      display: block;
      margin-bottom: 1rem;
      text-shadow: none;
    }

    .hero-subtitle {
      font-family: 'Crimson Pro', serif;
      font-style: italic;
      font-size: 1.35rem;
      color: rgba(255,255,255,0.8);
      margin-bottom: 0.5rem;
      letter-spacing: 0.02em;
    }

    .gold-rule {
      width: 80px;
      height: 2px;
      background: linear-gradient(to right, transparent, var(--gold), transparent);
      margin: 1.5rem 0;
    }

    .hero-desc {
      font-family: 'Crimson Pro', serif;
      font-size: 1.1rem;
      color: rgba(255,255,255,0.7);
      line-height: 1.75;
      margin-bottom: 2rem;
      max-width: 440px;
    }

    .hero-author {
      margin-bottom: 2.5rem;
    }

    .author-label {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-bottom: 0.3rem;
    }

    .author-name {
      font-family: 'Cinzel', serif;
      font-size: 1.3rem;
      font-weight: 600;
      color: var(--gold-lt);
      letter-spacing: 0.08em;
    }

    .author-creds {
      font-family: 'Crimson Pro', serif;
      font-size: 0.9rem;
      color: rgba(255,255,255,0.45);
      letter-spacing: 0.1em;
      margin-top: 0.2rem;
    }

    .hero-btns {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.9rem 2rem;
      font-family: 'Cinzel', serif;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      text-decoration: none;
      border-radius: 2px;
      transition: all 0.25s;
      cursor: pointer;
      border: none;
    }

    .btn-gold {
      background: linear-gradient(135deg, var(--gold-lt), var(--gold), var(--gold-dk));
      color: var(--forest-dk);
      box-shadow: 0 4px 20px rgba(201,168,76,0.4);
    }

    .btn-gold:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(201,168,76,0.5);
    }

    .btn-outline {
      background: transparent;
      color: var(--gold);
      border: 1.5px solid rgba(201,168,76,0.5);
    }

    .btn-outline:hover {
      border-color: var(--gold);
      background: rgba(201,168,76,0.1);
      transform: translateY(-3px);
    }

    /* ── BOOK COVER DISPLAY ── */
    .hero-visual {
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .cover-wrapper {
      position: relative;
    }

    .cover-glow {
      position: absolute;
      inset: -30px;
      background: radial-gradient(ellipse at center, rgba(201,168,76,0.25) 0%, transparent 70%);
      animation: glow-pulse 4s ease-in-out infinite;
      pointer-events: none;
    }

    @keyframes glow-pulse {
      0%, 100% { opacity: 0.7; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.05); }
    }

    .book-img {
      width: 320px;
      border-radius: 4px 14px 14px 4px;
      box-shadow:
        -8px 0 0 rgba(0,0,0,0.5),
        -12px 6px 30px rgba(0,0,0,0.6),
        30px 30px 80px rgba(0,0,0,0.4),
        0 0 0 1px rgba(201,168,76,0.2);
      display: block;
      position: relative;
      z-index: 2;
      animation: float 6s ease-in-out infinite;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(-1.5deg); }
      50% { transform: translateY(-14px) rotate(-1.5deg); }
    }

    .medallion {
      position: absolute;
      bottom: -20px;
      right: -20px;
      width: 90px;
      height: 90px;
      background: linear-gradient(135deg, var(--gold-lt), var(--gold), var(--gold-dk));
      border-radius: 50%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 10;
      box-shadow: 0 4px 20px rgba(0,0,0,0.4), inset 0 0 0 4px rgba(255,255,255,0.3);
      border: 3px solid rgba(255,255,255,0.4);
      padding: 0.4rem;
    }

    .medallion-text {
      font-family: 'Cinzel', serif;
      font-size: 0.38rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-align: center;
      color: var(--forest-dk);
      line-height: 1.4;
    }

    /* ── SECTIONS ── */
    .section { padding: 6rem 5%; }

    .section-inner { max-width: 1100px; margin: 0 auto; }

    .section-eyebrow {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      margin-bottom: 1.2rem;
    }

    .section-eyebrow span {
      font-family: 'Cinzel', serif;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold-dk);
    }

    .section-eyebrow::before,
    .section-eyebrow::after {
      content: '';
      height: 1px;
      width: 50px;
      background: var(--gold);
      opacity: 0.5;
    }

    h2 {
      font-family: 'Cinzel', serif;
      font-size: clamp(1.6rem, 2.5vw, 2.2rem);
      font-weight: 700;
      color: var(--forest-dk);
      text-align: center;
      letter-spacing: 0.04em;
      margin-bottom: 3rem;
      line-height: 1.25;
    }

    /* ── STATS ── */
    .stats-band {
      background: linear-gradient(135deg, var(--forest-dk), var(--forest));
      padding: 3.5rem 5%;
      border-top: 1px solid rgba(201,168,76,0.2);
      border-bottom: 1px solid rgba(201,168,76,0.2);
    }

    .stats-grid {
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      text-align: center;
    }

    .stat-divider {
      width: 1px;
      background: rgba(201,168,76,0.2);
      margin: 0 auto;
    }

    .stat-number {
      font-family: 'Cinzel', serif;
      font-size: 2.8rem;
      font-weight: 900;
      background: linear-gradient(135deg, var(--gold-lt), var(--gold));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1;
      margin-bottom: 0.4rem;
    }

    .stat-label {
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.45);
    }

    /* ── ABOUT ── */
    #about { background: var(--cream); }

    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }

    .body-text {
      font-family: 'Crimson Pro', serif;
      font-size: 1.13rem;
      color: #3a3a3a;
      line-height: 1.85;
      margin-bottom: 1.2rem;
    }

    .pull-quote {
      border-left: 3px solid var(--gold);
      padding: 1.5rem 1.5rem 1.5rem 2rem;
      margin: 2rem 0;
      background: linear-gradient(to right, rgba(201,168,76,0.08), transparent);
    }

    .pull-quote blockquote {
      font-family: 'Crimson Pro', serif;
      font-size: 1.25rem;
      font-style: italic;
      color: var(--forest-dk);
      line-height: 1.6;
    }

    .pull-quote cite {
      display: block;
      margin-top: 0.6rem;
      font-family: 'Inter', sans-serif;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold-dk);
    }

    /* guide badge */
    .guide-badge {
      background: linear-gradient(135deg, var(--forest-dk), var(--forest));
      border: 2px solid rgba(201,168,76,0.4);
      border-radius: 8px;
      padding: 2rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .guide-badge::before {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        45deg, transparent, transparent 20px,
        rgba(201,168,76,0.02) 20px, rgba(201,168,76,0.02) 21px
      );
    }

    .guide-badge-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      display: block;
    }

    .guide-badge-title {
      font-family: 'Cinzel', serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.75rem;
    }

    .guide-badge-desc {
      font-family: 'Crimson Pro', serif;
      font-size: 1.05rem;
      color: rgba(255,255,255,0.7);
      line-height: 1.6;
      position: relative;
    }

    /* ── READ SECTION ── */
    #read {
      background: linear-gradient(to bottom, var(--forest-dk), #0a2018);
      padding: 5rem 5%;
    }

    #read h2 { color: var(--white); }
    #read .section-eyebrow span { color: var(--gold-lt); }
    #read .section-eyebrow::before,
    #read .section-eyebrow::after { background: var(--gold-lt); }

    .read-options {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 1rem;
    }

    .read-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(201,168,76,0.2);
      border-radius: 6px;
      padding: 2.5rem 2rem;
      text-align: center;
      transition: all 0.3s;
      position: relative;
      overflow: hidden;
    }

    .read-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(to right, var(--gold-dk), var(--gold), var(--gold-dk));
      opacity: 0;
      transition: opacity 0.3s;
    }

    .read-card:hover {
      background: rgba(255,255,255,0.07);
      border-color: rgba(201,168,76,0.5);
      transform: translateY(-4px);
    }

    .read-card:hover::before { opacity: 1; }

    .read-icon {
      font-size: 2.5rem;
      margin-bottom: 1.2rem;
      display: block;
    }

    .read-card-title {
      font-family: 'Cinzel', serif;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.75rem;
    }

    .read-card-desc {
      font-family: 'Crimson Pro', serif;
      font-size: 1rem;
      color: rgba(255,255,255,0.6);
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }

    .read-btn {
      display: inline-block;
      padding: 0.65rem 1.5rem;
      font-family: 'Cinzel', serif;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      text-decoration: none;
      border: 1.5px solid rgba(201,168,76,0.5);
      color: var(--gold-lt);
      border-radius: 2px;
      transition: all 0.2s;
    }

    .read-btn:hover {
      background: var(--gold);
      color: var(--forest-dk);
      border-color: var(--gold);
    }

    .read-btn-primary {
      background: linear-gradient(135deg, var(--gold-lt), var(--gold));
      color: var(--forest-dk);
      border-color: var(--gold);
      font-weight: 700;
    }

    .read-btn-primary:hover {
      box-shadow: 0 4px 20px rgba(201,168,76,0.4);
    }

    /* ── CHAPTERS ── */
    #chapters { background: var(--paper); }

    .chapters-list { margin-top: 1rem; }

    .chapter-item {
      display: grid;
      grid-template-columns: 70px 1fr;
      gap: 2rem;
      padding: 2rem 0;
      border-bottom: 1px solid rgba(201,168,76,0.2);
      transition: all 0.2s;
      align-items: start;
    }

    .chapter-item:first-child { border-top: 1px solid rgba(201,168,76,0.2); }

    .chapter-num {
      font-family: 'Cinzel', serif;
      font-size: 2rem;
      font-weight: 900;
      color: rgba(201,168,76,0.3);
      line-height: 1;
      transition: color 0.2s;
      padding-top: 0.2rem;
    }

    .chapter-item:hover .chapter-num { color: var(--gold); }

    .chapter-name {
      font-family: 'Cinzel', serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--forest-dk);
      margin-bottom: 0.4rem;
      letter-spacing: 0.03em;
    }

    .chapter-desc {
      font-family: 'Crimson Pro', serif;
      font-size: 1rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ── RESEARCH ── */
    #research {
      background: linear-gradient(135deg, var(--forest) 0%, var(--forest-dk) 100%);
    }

    #research h2 { color: var(--white); }
    #research .section-eyebrow span { color: var(--gold-lt); }
    #research .section-eyebrow::before,
    #research .section-eyebrow::after { background: var(--gold-lt); }

    .questions-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.2rem;
    }

    .q-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(201,168,76,0.15);
      border-radius: 4px;
      padding: 1.75rem;
      display: flex;
      gap: 1.2rem;
      align-items: start;
      transition: all 0.2s;
    }

    .q-card:hover {
      background: rgba(255,255,255,0.07);
      border-color: rgba(201,168,76,0.35);
    }

    .q-num {
      font-family: 'Cinzel', serif;
      font-size: 1.5rem;
      font-weight: 900;
      color: var(--gold);
      opacity: 0.6;
      line-height: 1;
      flex-shrink: 0;
      margin-top: 0.1rem;
    }

    .q-text {
      font-family: 'Crimson Pro', serif;
      font-size: 1.05rem;
      color: rgba(255,255,255,0.78);
      line-height: 1.65;
    }

    /* ── AUDIENCE ── */
    #audience { background: var(--cream); }

    .audience-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .audience-card {
      background: var(--white);
      border: 1px solid rgba(201,168,76,0.2);
      border-radius: 6px;
      padding: 2rem;
      position: relative;
      overflow: hidden;
      transition: all 0.25s;
    }

    .audience-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(to right, var(--forest), var(--gold));
      opacity: 0;
      transition: opacity 0.25s;
    }

    .audience-card:hover { transform: translateY(-4px); box-shadow: 0 10px 40px rgba(0,0,0,0.1); }
    .audience-card:hover::after { opacity: 1; }

    .audience-icon { font-size: 2rem; margin-bottom: 1rem; display: block; }

    .audience-title {
      font-family: 'Cinzel', serif;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      color: var(--forest-dk);
      margin-bottom: 0.6rem;
      text-transform: uppercase;
    }

    .audience-desc {
      font-family: 'Crimson Pro', serif;
      font-size: 1rem;
      color: var(--muted);
      line-height: 1.65;
    }

    /* ── AUTHOR ── */
    #author {
      background: linear-gradient(to bottom, var(--forest-dk), #0a1f12);
      padding: 6rem 5%;
    }

    .author-section {
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 4rem;
      align-items: start;
    }

    .author-portrait {
      position: relative;
    }

    .author-portrait-placeholder {
      width: 100%;
      aspect-ratio: 3/4;
      background: linear-gradient(145deg, var(--forest), var(--forest-lt));
      border-radius: 6px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      border: 2px solid rgba(201,168,76,0.3);
      gap: 0.75rem;
    }

    .author-portrait-placeholder span {
      font-size: 4rem;
    }

    .author-portrait-placeholder p {
      font-family: 'Cinzel', serif;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
    }

    .author-gold-line {
      width: 100%;
      height: 2px;
      background: linear-gradient(to right, var(--gold), var(--gold-dk));
